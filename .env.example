# 어드민 API 보호용 시크릿 (대시보드 API 키 관리 페이지에서 사용)
ADMIN_SECRET=your-admin-secret-here

# CORS — 허용할 프론트엔드 도메인 (쉼표로 여러 개 가능)
# 예: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Firecrawl (크롤링 분석 기능용)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxx

# DB — docker-compose.yml의 POSTGRES_USER/PASSWORD와 일치해야 함
DATABASE_URL=postgresql+psycopg2://admin:admin@localhost:5434/contentguard_db

# 텍스트 추출 전용 (크롤링 마크다운 → 사용자 텍스트 추출) — 필수
# 허용값: ollama | openai | anthropic | gemini | deepseek
# 권장: 7B~8B 모델 (JSON 형식 출력 신뢰도 중요)
LLM_PROVIDER_EXTRACT=ollama
LLM_MODEL_EXTRACT=qwen2.5:7b

# 설명 생성 전용 (위험도 판단 근거 한국어 설명) — 필수
# 허용값: ollama | openai | anthropic | gemini | deepseek
# 권장: 3B~4B 모델로 충분 (단순 한국어 작성 작업)
LLM_PROVIDER_EXPLAIN=ollama
LLM_MODEL_EXPLAIN=qwen2.5:3b

# Ollama (로컬 실행 시 — WSL에서 Windows Ollama 접근 시 ip route | grep default 로 게이트웨이 IP 확인)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# 클라우드 LLM API 키 (사용할 공급자에 맞는 키만 설정하면 됩니다)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # 기본값, 변경 불필요

# 모델 설정 — prediction_service에 등록된 모델 name 중 하나
MODEL_PRIMARY=logistic_regression

# 판단 정책
#   primary_only  : primary 모델 결과만 사용 (기본)
#   conservative  : 전체 모델 중 가장 높은 위험 점수 채택
#   ensemble_mean : 전체 모델 점수 평균
#   majority_vote : 위험 등급 다수결
DECISION_POLICY=primary_only

# 웹훅 데모용 클라이언트 API 키 (어드민 페이지에서 발급 후 입력)
DEMO_CLIENT_API_KEY=cg-xxxxxxxxxxxxxxxx
