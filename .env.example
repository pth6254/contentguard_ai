# DB вҖ” docker-compose.ymlмқҳ POSTGRES_USER/PASSWORDмҷҖ мқјм№ҳн•ҙм•ј н•Ё
DATABASE_URL=postgresql+psycopg2://admin:admin@localhost:5434/contentguard_db

# Ollama (WSLм—җм„ң Windows Ollama м ‘к·ј мӢң ip route | grep default лЎң кІҢмқҙнҠёмӣЁмқҙ IP нҷ•мқё)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# лӘЁлҚё м„Өм • вҖ” prediction_serviceм—җ л“ұлЎқлҗң лӘЁлҚё name мӨ‘ н•ҳлӮҳ
MODEL_PRIMARY=logistic_regression

# нҢҗлӢЁ м •мұ…
#   primary_only  : primary лӘЁлҚё кІ°кіјл§Ң мӮ¬мҡ© (кё°ліё)
#   conservative  : м „мІҙ лӘЁлҚё мӨ‘ к°ҖмһҘ лҶ’мқҖ мң„н—ҳ м җмҲҳ мұ„нғқ
#   ensemble_mean : м „мІҙ лӘЁлҚё м җмҲҳ нҸүк· 
#   majority_vote : мң„н—ҳ л“ұкёү лӢӨмҲҳкІ°
DECISION_POLICY=primary_only
